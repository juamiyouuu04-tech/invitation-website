!DOCTYPE html>
<html>
<head>
  <title>Invitation</title>
  <style>
    body {
      text-align: center;
      font-family: Arial;
    }

    img {
      width: 250px;
      margin-top: 20px;
    }

    button {
      padding: 10px 20px;
      font-size: 18px;
      margin: 10px;
      position: relative;
    }

    #no {
      position: absolute;
    }
  </style>
</head>
<body>

  <h1>Will you come to my party? 🎉</h1>

  <!-- Mommy and Daddy -->
  <img src=https://drive.google.com/file/d/15ZxSDqRN-7bl08WAq13AgppHXd55fcBU/view?usp=sharing>

  <br><br>

  <button onclick="alert('Yay! 🎉')">Yes</button>
  <button id="no">No</button>

  <script>
    const noBtn = document.getElementById("no");

    noBtn.addEventListener("mouseover", function() {
      const x = Math.random() * (window.innerWidth - 100);
      const y = Math.random() * (window.innerHeight - 50);

      noBtn.style.position = "absolute";
      noBtn.style.left = x + "px";
      noBtn.style.top = y + "px";
    });
  </script>

</body>
</html>
